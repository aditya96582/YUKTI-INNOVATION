# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Set USE_MONGODB=true to enable MongoDB (requires MongoDB installation)
# Set USE_MONGODB=false to use in-memory database (default for development)
USE_MONGODB=false
MONGODB_URI=mongodb://localhost:27017/campusconnect

# CORS Configuration
CORS_ORIGIN=http://localhost:8080

# AI Configuration
AI_MATCH_THRESHOLD=85
AI_HIGH_CONFIDENCE_THRESHOLD=98

# Gemini API Key (for AI image generation)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Gemini API (for image analysis and generation)
GOOGLE_API_KEY=AIzaSyBPY29xEbz0QmTsrzcDhKZpRwh0xNs5JSI

# Notification Configuration
ENABLE_PUSH_NOTIFICATIONS=false
FCM_SERVER_KEY=your_firebase_server_key_here

# Partner API Keys (for production)
AMAZON_API_KEY=your_amazon_api_key
FLIPKART_API_KEY=your_flipkart_api_key
JANAUSHADHI_API_KEY=your_janaushadhi_api_key

# Security
JWT_SECRET=your_jwt_secret_here_change_in_production
SESSION_SECRET=your_session_secret_here

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
